---
import { PageHeader } from "@components/features/page-header";
import SimpleMizukiLayout from "@layouts/SimpleMizukiLayout.astro";
import { getCategoryList } from "@utils/content-utils";

const categories = await getCategoryList();
---

<SimpleMizukiLayout title="分类">
	<div class="grid gap-4">
		<section class="card-base px-6 py-6 md:px-8">
			<PageHeader title="分类" />
			<p class="mt-2 text-sm leading-7 text-black/60 dark:text-white/60">
				这里保留旧站的 `/categories/` 入口，分类本身仍然由归档页统一承载。
			</p>
		</section>

		<section class="card-base px-6 py-6 md:px-8">
			<div class="grid gap-3 md:grid-cols-2">
				{
					categories.map((category) => (
						<a
							href={category.url}
							class="rounded-2xl border border-black/8 px-4 py-4 transition hover:bg-black/[0.02] dark:border-white/10 dark:hover:bg-white/[0.04]"
						>
							<div class="text-base font-semibold text-black/85 dark:text-white/85">
								{category.name}
							</div>
							<div class="mt-1 text-sm text-black/50 dark:text-white/50">
								{category.count} 篇文章
							</div>
						</a>
					))
				}
			</div>
		</section>
	</div>
</SimpleMizukiLayout>
