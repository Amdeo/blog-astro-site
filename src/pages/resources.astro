---
import { PageHeader } from "@components/features/page-header";
import SimpleMizukiLayout from "@layouts/SimpleMizukiLayout.astro";
import { url } from "@utils/url-utils";

const resources = [
	{
		title: "文章归档",
		description: "按时间轴浏览全部迁移文章，并支持分类与标签筛选。",
		href: url("/archive/"),
	},
	{
		title: "全部文章",
		description: "从新的文章列表页进入当前博客内容。",
		href: url("/posts/"),
	},
	{
		title: "关于本站",
		description: "查看这个站点的定位、内容范围和维护方向。",
		href: url("/about/"),
	},
	{
		title: "RSS",
		description: "订阅 RSS，沿用博客迁移后的内容流。",
		href: url("/rss/"),
	},
	{
		title: "Atom",
		description: "需要 Atom 的阅读器可以直接使用这一份源。",
		href: url("/atom/"),
	},
];
---

<SimpleMizukiLayout title="资源">
	<div class="grid gap-4">
		<section class="card-base px-6 py-6 md:px-8">
			<PageHeader title="资源" />
			<p class="mt-2 text-sm leading-7 text-black/60 dark:text-white/60">
				旧站的 `/resources/` 页面没有沉淀正文内容，这里保留入口，并把常用入口集中到一起。
			</p>
		</section>

		<section class="grid gap-4 md:grid-cols-2">
			{
				resources.map((item) => (
					<a
						href={item.href}
						class="card-base rounded-[var(--radius-large)] px-6 py-5 transition hover:bg-black/[0.02] dark:hover:bg-white/[0.03]"
					>
						<div class="text-lg font-semibold text-black/90 dark:text-white/90">
							{item.title}
						</div>
						<p class="mt-2 text-sm leading-7 text-black/60 dark:text-white/60">
							{item.description}
						</p>
					</a>
				))
			}
		</section>
	</div>
</SimpleMizukiLayout>
