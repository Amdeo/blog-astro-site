---
import { PageHeader } from "@components/features/page-header";
import SimpleMizukiLayout from "@layouts/SimpleMizukiLayout.astro";
import { getTagList } from "@utils/content-utils";
import { getTagUrl } from "@utils/url-utils";

const tags = await getTagList();
---

<SimpleMizukiLayout title="标签">
	<div class="grid gap-4">
		<section class="card-base px-6 py-6 md:px-8">
			<PageHeader title="标签" />
			<p class="mt-2 text-sm leading-7 text-black/60 dark:text-white/60">
				这里保留旧站的 `/tags/` 入口，点击后会跳到归档页对应的标签筛选。
			</p>
		</section>

		<section class="card-base px-6 py-6 md:px-8">
			<div class="flex flex-wrap gap-3">
				{
					tags.map((tag) => (
						<a
							href={getTagUrl(tag.name)}
							class="rounded-full bg-black/[0.04] px-4 py-2 text-sm text-black/70 transition hover:bg-black/[0.07] dark:bg-white/[0.06] dark:text-white/70 dark:hover:bg-white/[0.1]"
						>
							#{tag.name}
							<span class="ml-2 text-xs opacity-60">
								{tag.count}
							</span>
						</a>
					))
				}
			</div>
		</section>
	</div>
</SimpleMizukiLayout>
