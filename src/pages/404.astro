---
import SimpleMizukiLayout from "../layouts/SimpleMizukiLayout.astro";
---

<SimpleMizukiLayout title="页面不存在" description="未找到您要访问的页面。">
	<div class="card-base z-10 px-6 py-12 text-center md:px-9">
		<h1 class="text-3xl font-bold text-black/90 dark:text-white/90">页面不存在</h1>
		<p class="mt-3 text-black/60 dark:text-white/60">您访问的页面可能已移动，或者链接有误。</p>
		<a href="/blog-astro-site/" class="mt-6 inline-flex rounded-xl bg-[var(--simple-primary)] px-5 py-2.5 text-white">
			返回首页
		</a>
	</div>
</SimpleMizukiLayout>
